generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum FitnessGoal {
  LOSE_WEIGHT
  BUILD_MUSCLE
  TONE
  FLEXIBILITY
  REHAB
  IMPROVE_TECHNIQUE
  STAY_ACTIVE
  REHABILITATION
}

enum FitnessLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum ExerciseDifficulty {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum ExerciseCategory {
  STRENGTH
  CARDIO
  MOBILITY
  HIIT
}

model User {
  id           String           @id @default(cuid())
  email        String           @unique
  name         String
  passwordHash String?
  pictureUrl   String?
  emailVerifiedAt DateTime?
  googleSubject String?          @unique
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  profile      Profile?
  workouts     WorkoutSession[]
  programEnrollments ProgramEnrollment[]
  lessonProgress LessonProgress[]
  achievements Achievement[]
  emailVerificationTokens EmailVerificationToken[]
  passwordResetTokens PasswordResetToken[]
}

model EmailVerificationToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Profile {
  id                  String       @id @default(cuid())
  userId              String       @unique
  goal                FitnessGoal
  level               FitnessLevel
  age                 Int?
  heightCm            Int?
  weightKg            Float?
  gender              String?
  activityLevel       String?
  injuries            String[]     @default([])
  isOnboardingComplete Boolean     @default(false)
  completedAt         DateTime?
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
  user                User         @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Exercise {
  id               String             @id @default(cuid())
  slug             String             @unique
  name             String
  description      String
  category         ExerciseCategory
  difficulty       ExerciseDifficulty
  primaryMuscles   String[]           @default([])
  secondaryMuscles String[]           @default([])
  equipment        String[]           @default([])
  sets             Int                @default(3)
  reps             Int                @default(10)
  estimatedSeconds Int                @default(45)
  videoUrl         String?
  thumbnailUrl     String?
  rulesConfig      Json?
  commonErrors     String[]           @default([])
  modifications    String[]           @default([])
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  workouts         WorkoutSession[]
  rules            ExerciseRule[]
}

model ExerciseRule {
  id         String   @id @default(cuid())
  exerciseId String
  code       String
  phase      String
  joint      String
  landmarks  Json
  angleMin   Float
  angleMax   Float
  severity   String
  feedback   String
  order      Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  exercise   Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)

  @@unique([exerciseId, code])
  @@index([exerciseId])
}

model WorkoutSession {
  id              String    @id @default(cuid())
  userId          String
  exerciseId      String
  repCount        Int
  averageScore    Int
  durationSeconds Int
  scoreHistory    Int[]     @default([])
  completedAt     DateTime  @default(now())
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  exercise        Exercise  @relation(fields: [exerciseId], references: [id])

  @@index([userId, completedAt])
  @@index([exerciseId])
}

model Program {
  id                         String              @id
  name                       String
  description                String
  difficulty                 ExerciseDifficulty
  durationWeeks              Int
  sessionsPerWeek            Int
  estimatedMinutesPerSession Int
  emoji                      String
  goals                      String[]            @default([])
  weeks                      Json
  createdAt                  DateTime            @default(now())
  updatedAt                  DateTime            @updatedAt
  enrollments                ProgramEnrollment[]
}

model ProgramEnrollment {
  id              String   @id @default(cuid())
  userId          String
  programId       String
  startedAt       DateTime @default(now())
  completedDayIds String[] @default([])
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  program         Program  @relation(fields: [programId], references: [id], onDelete: Cascade)

  @@unique([userId, programId])
  @@index([userId])
  @@index([programId])
}

enum LessonType {
  ARTICLE
  VIDEO
}

enum LessonCategory {
  TECHNIQUE
  TRAINING
  RECOVERY
  BEGINNER
}

model Lesson {
  id               String           @id
  type             LessonType
  category         LessonCategory
  emoji            String
  title            String
  summary          String
  body             String[]         @default([])
  keyTakeaways     String[]         @default([])
  readMinutes      Int?
  durationMinutes  Int?
  youtubeVideoId   String?
  linkedExerciseId String?
  order            Int              @default(0)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  progress         LessonProgress[]
}

model LessonProgress {
  id          String   @id @default(cuid())
  userId      String
  lessonId    String
  completedAt DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson      Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@index([userId])
  @@index([lessonId])
}

model Achievement {
  id         String   @id @default(cuid())
  userId     String
  type       String
  unlockedAt DateTime @default(now())
  metadata   Json?
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type])
  @@index([userId])
}
